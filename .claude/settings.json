{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm start)",
      "Bash(npm test)",
      "Bash(npm ls:*)",
      "Bash(npm outdated)",
      "Bash(npm audit)",
      "Bash(node server/*)",
      "Bash(node -e:*)",
      "Bash(npx nodemon:*)",
      "Bash(curl -fsS http://localhost:*)",
      "Bash(curl -fsSI http://localhost:*)",
      "Bash(curl -fsS -o:*)",
      "Bash(curl -fsS -F:*)",
      "Bash(curl -fsS -N:*)",
      "Bash(lsof -ti :*)",
      "Bash(unzip -l:*)",
      "Bash(file:*)",
      "Bash(identify:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /)",
      "Bash(npm publish:*)",
      "Bash(git push --force:*)"
    ]
  }
}
